<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Payment Success - GreenEquip</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/modern.css" />
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  </head>
  <body class="bg-gray-50 min-h-screen flex items-center justify-center p-4">
    <div class="max-w-md w-full animate-fade-in-up">
      <!-- Success Animation -->
      <div class="text-center mb-8">
        <div
          class="w-24 h-24 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-6 shadow-lg shadow-emerald-200 animate-bounce"
        >
          <i data-lucide="check" class="w-12 h-12 text-emerald-600"></i>
        </div>
        <h1 class="text-3xl font-bold text-gray-900 mb-2">
          Payment Successful!
        </h1>
        <p class="text-gray-500">Your booking has been confirmed.</p>
      </div>

      <!-- Receipt Card -->
      <div class="bg-white p-8 rounded-3xl shadow-xl relative overflow-hidden">
        <!-- Decorative circles -->
        <div
          class="absolute -left-3 top-1/2 -translate-y-1/2 w-6 h-6 bg-gray-50 rounded-full"
        ></div>
        <div
          class="absolute -right-3 top-1/2 -translate-y-1/2 w-6 h-6 bg-gray-50 rounded-full"
        ></div>
        <div
          class="absolute left-8 right-8 top-1/2 border-t-2 border-dashed border-gray-100"
        ></div>

        <!-- Top Section -->
        <div class="pb-8 text-center">
          <p class="text-sm text-gray-400 uppercase tracking-wider mb-1">
            Total Paid
          </p>
          <p class="text-4xl font-bold text-emerald-600">₹<%= amount %></p>
        </div>

        <!-- Bottom Section -->
        <div class="pt-8 space-y-4">
          <div class="flex justify-between items-center">
            <span class="text-gray-500">Equipment</span>
            <span class="font-bold text-gray-900"><%= listing.name %></span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-500">Duration</span>
            <span class="font-bold text-gray-900"><%= days %> Days</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-gray-500">Date</span>
            <span class="font-bold text-gray-900"
              ><%= new Date().toLocaleDateString() %></span
            >
          </div>

          <div class="bg-gray-50 p-3 rounded-xl mt-4">
            <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">
              Transaction Hash
            </p>
            <div class="flex items-center gap-2">
              <p class="text-xs font-mono text-gray-600 truncate flex-1">
                <%= txHash %>
              </p>
              <a
                href="https://sepolia.etherscan.io/tx/<%= txHash %>"
                target="_blank"
                class="text-emerald-600 hover:text-emerald-700 p-1"
              >
                <i data-lucide="external-link" class="w-4 h-4"></i>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div
        class="mt-8 text-center flex flex-col sm:flex-row gap-4 justify-center"
      >
        <button
          onclick="downloadReceipt('<%= listing.name %>', '<%= amount %>', '<%= days %>', '<%= new Date().toLocaleDateString() %>', '<%= txHash %>')"
          class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white px-8 py-3.5 rounded-xl font-bold transition hover-lift shadow-lg"
        >
          <i data-lucide="download" class="w-5 h-5"></i> Download Receipt
        </button>
        <a
          href="/farmer"
          class="inline-flex items-center gap-2 bg-gray-900 hover:bg-gray-800 text-white px-8 py-3.5 rounded-xl font-bold transition hover-lift shadow-lg"
        >
          <i data-lucide="arrow-left" class="w-5 h-5"></i> Back to Dashboard
        </a>
      </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script>
      if (typeof lucide !== "undefined") {
        lucide.createIcons();
      }

      function downloadReceipt(equipment, amount, days, date, txHash) {
        // Create PDF
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF();

        // Add company header
        doc.setFillColor(4, 120, 87); // Emerald color
        doc.rect(0, 0, 210, 25, "F");

        doc.setTextColor(255, 255, 255);
        doc.setFontSize(20);
        doc.setFont("helvetica", "bold");
        doc.text("GreenEquip", 105, 15, null, null, "center");

        doc.setFontSize(10);
        doc.setFont("helvetica", "normal");
        doc.text(
          "Farm Machinery Rental Platform",
          105,
          22,
          null,
          null,
          "center"
        );

        // Reset color
        doc.setTextColor(0, 0, 0);

        // Title
        doc.setFontSize(16);
        doc.setFont("helvetica", "bold");
        doc.text("PAYMENT RECEIPT", 105, 40, null, null, "center");

        // Horizontal line
        doc.setDrawColor(200, 200, 200);
        doc.line(20, 45, 190, 45);

        // Receipt info
        const receiptNo = txHash.substring(0, 8).toUpperCase();
        doc.setFont("helvetica", "normal");
        doc.setFontSize(10);
        doc.text(`Receipt #: ${receiptNo}`, 20, 52);
        doc.text(`Date: ${date}`, 150, 52);

        // Transaction details
        doc.setFont("helvetica", "bold");
        doc.setFontSize(12);
        doc.text("Transaction Details", 20, 62);

        // Details box
        doc.setDrawColor(220, 220, 220);
        doc.rect(20, 67, 170, 50);

        // Labels
        doc.setFont("helvetica", "bold");
        doc.setFontSize(10);
        doc.text("Equipment:", 25, 77);
        doc.text("Duration:", 25, 87);
        doc.text("Amount Paid:", 25, 97);
        doc.text("Transaction Hash: ", 25, 107);

        // Values
        doc.setFont("helvetica", "normal");
        doc.text(equipment, 55, 77);
        doc.text(`${days} Days`, 55, 87);
        doc.setFont("helvetica", "bold");
        doc.setTextColor(4, 120, 87);

        // Format amount to remove spaces and add Rs symbol
        const formattedAmount = `Rs ${amount.toString().replace(/\s+/g, "")}`;
        doc.text(formattedAmount, 55, 97);

        // Reset color and font
        doc.setTextColor(0, 0, 0);
        doc.setFont("helvetica", "normal");
        doc.setFontSize(8);
        doc.text(txHash, 55, 107, { maxWidth: 130 });

        // Footer
        doc.setFontSize(10);
        doc.setTextColor(4, 120, 87);
        doc.text(
          "Thank you for your business!",
          105,
          125,
          null,
          null,
          "center"
        );

        doc.setTextColor(100, 100, 100);
        doc.text(
          "GreenEquip - Farm Machinery Rental Platform",
          105,
          132,
          null,
          null,
          "center"
        );

        // Save the PDF
        doc.save(`receipt-${receiptNo}.pdf`);
      }
    </script>
  </body>
</html>
