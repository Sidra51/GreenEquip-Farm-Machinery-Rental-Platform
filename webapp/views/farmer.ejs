<!DOCTYPE html>
<html lang="en" id="html">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Farmer Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
  // Warning: Using CDN for Tailwind CSS in production is not recommended.
  // For production, install Tailwind CSS as a PostCSS plugin or use the Tailwind CLI.
  </script>
  <link rel="stylesheet" href="/css/modern.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
</head>
<body class="bg-gray-50 min-h-screen">

  <!-- Navbar -->
  <nav class="sticky top-0 z-40 bg-white/80 backdrop-blur-md border-b border-gray-200">
    <div class="container mx-auto px-4 py-3 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <div class="bg-emerald-100 p-2 rounded-xl">
          <i data-lucide="tractor" class="w-6 h-6 text-emerald-600"></i>
        </div>
        <span class="text-xl font-bold text-gray-800" data-en="Farmer Portal" data-mr="शेतकरी पोर्टल" data-hi="किसान पोर्टल">Farmer Portal</span>
      </div>
      
      <div class="flex items-center gap-4">
        <div class="hidden md:flex items-center gap-2 bg-emerald-50 px-4 py-2 rounded-full">
          <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
          <span class="text-sm font-medium text-emerald-700" data-en="Live Market" data-mr="थेट बाजार" data-hi="लाइव बाजार">Live Market</span>
        </div>
            
        <!-- Translation Button -->
        <button 
          id="translateBtn" 
          onclick="toggleLanguage()" 
          class="flex items-center gap-2 text-gray-500 hover:text-blue-500 transition font-medium"
          aria-label="Toggle Language"
        >
          <i data-lucide="globe" class="w-5 h-5"></i>
          <span class="hidden md:inline" id="translateBtnText">Translate</span>
        </button>
            
        <a href="/auth/logout" class="p-2 hover:bg-gray-100 rounded-full transition text-gray-500 hover:text-red-500">
          <i data-lucide="log-out" class="w-5 h-5"></i>
        </a>
      </div>
    </div>
  </nav>

  <div class="container mx-auto px-4 py-8">
    
    <!-- Search & Filter Section -->
    <div class="glass rounded-3xl p-6 mb-10 animate-fade-in-up">
      <form action="/farmer" method="GET" class="grid md:grid-cols-4 gap-4">
        <div class="md:col-span-2 relative">
          <i data-lucide="search" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400"></i>
          <input type="text" name="q" value="<%= query %>" placeholder="Search for tractors, seeders..." data-en="Search for tractors, seeders..." data-mr="ट्रैक्टर, सीडर्स के लिए खोजें..." data-hi="ट्रैक्टर, सीडर्स के लिए खोजें..." class="w-full pl-12 pr-4 py-3 rounded-xl border border-gray-200 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 outline-none transition bg-white/50">
        </div>
        
        <div class="relative">
          <i data-lucide="map-pin" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400"></i>
          <select name="region" class="w-full pl-12 pr-4 py-3 rounded-xl border border-gray-200 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 outline-none transition bg-white/50 appearance-none">
            <option value="" data-en="All Regions" data-mr="सर्व क्षेत्र" data-hi="सभी क्षेत्र">All Regions</option>
            <% REGIONS.forEach(r => { %>
              <option value="<%= r %>" <%= region == r ? 'selected' : '' %>><%= r %></option>
            <% }) %>
          </select>
        </div>

        <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 rounded-xl transition shadow-lg shadow-emerald-200 flex items-center justify-center gap-2">
          <i data-lucide="filter" class="w-5 h-5"></i> <span data-en="Filter" data-mr="फिल्टर" data-hi="फ़िल्टर">Filter</span>
        </button>
      </form>

      <!-- Category Tags -->
      <div class="flex flex-wrap gap-2 mt-4">
        <a href="/farmer" class="px-4 py-1.5 rounded-full text-sm font-medium transition <%= category === 'all' ? 'bg-emerald-600 text-white shadow-md' : 'bg-white text-gray-600 hover:bg-gray-100 border border-gray-200' %>">All</a>
        <% CATEGORIES.forEach(c => { %>
          <a href="/farmer?category=<%= c %>&region=<%= region %>&q=<%= query %>" class="px-4 py-1.5 rounded-full text-sm font-medium transition <%= category === c ? 'bg-emerald-600 text-white shadow-md' : 'bg-white text-gray-600 hover:bg-gray-100 border border-gray-200' %>">
            <%= c %>
          </a>
        <% }) %>
      </div>

      <!-- Listings Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
        <% if (listings.length > 0) { %>
          <% listings.forEach(l => { %>
            <div class="glass rounded-3xl p-6 hover:shadow-xl transition group flex flex-col h-full">
              
              <!-- Image Section -->
              <div class="relative h-48 mb-4 rounded-2xl overflow-hidden group-hover:scale-[1.02] transition-transform duration-300">
                <img src="<%= l.img %>" alt="<%= l.name %>" class="w-full h-full object-cover">
                <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold text-emerald-700 shadow-sm">
                  <%= l.category %>
                </div>
              </div>

              <div class="flex justify-between items-start mb-4">
                <div>
                  <h3 class="text-xl font-bold text-gray-900 mb-1"><%= l.name %></h3>
                  <p class="text-sm text-gray-500"><i data-lucide="map-pin" class="w-3 h-3 inline mr-1"></i><%= l.region %></p>
                </div>
              </div>
              
              <div class="flex items-center gap-2 mb-4 text-sm text-gray-500">
                <i data-lucide="user" class="w-4 h-4"></i>
                <span><%= l.sellerName || 'Verified Seller' %></span>
              </div>

              <div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-between">
                <div>
                  <span class="text-xs text-gray-400 block">Price per day</span>
                  <span class="text-xl font-bold text-gray-900">₹<%= l.pricePerDay %></span>
                </div>
                <button class="book-now-button bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-xl font-medium transition shadow-md shadow-emerald-100" data-id="<%= l._id %>" data-name="<%= l.name %>" data-price="<%= l.pricePerDay %>" data-en="Book Now" data-mr="आता बुक करा" data-hi="अभी बुक करें">
                  Book Now
                </button>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-span-full py-12 text-center">
            <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4 text-gray-400">
              <i data-lucide="search-x" class="w-10 h-10"></i>
            </div>
            <h3 class="text-xl font-semibold text-gray-600 mb-2" data-en="No equipment found" data-mr="कोणतीही उपकरणे सापडली नाहीत" data-hi="कोई उपकरण नहीं मिला">No equipment found</h3>
            <p class="text-gray-500" data-en="Try adjusting your search filters" data-mr="आपले शोध फिल्टर समायोजित करण्याचा प्रयत्न करा" data-hi="अपने खोज फिल्टर समायोजित करने का प्रयास करें">Try adjusting your search filters</p>
          </div>
        <% } %>
      </div>
    </div>

    <!-- My Bookings Section -->
    <h2 class="text-2xl font-bold text-gray-800 mb-6" data-en="My Bookings" data-mr="माझे बुकिंग" data-hi="मेरी बुकिंग">My Bookings</h2>
    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden mb-12">
      <% if (bookings.length > 0) { %>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50 border-b border-gray-100">
              <tr>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider" data-en="Equipment" data-mr="उपकरण" data-hi="उपकरण">Equipment</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider" data-en="Dates" data-mr="तारीख" data-hi="तिथियाँ">Dates</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider" data-en="Amount" data-mr="रक्कम" data-hi="राशि">Amount</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider" data-en="Status" data-mr="स्थिती" data-hi="स्थिति">Status</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider" data-en="Action" data-mr="क्रिया" data-hi="कार्य">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% bookings.forEach(b => { %>
                <tr class="hover:bg-gray-50/50 transition">
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 rounded-lg bg-gray-100 flex items-center justify-center text-gray-500">
                        <i data-lucide="tractor" class="w-5 h-5"></i>
                      </div>
                      <div>
                        <p class="font-medium text-gray-900" data-en="<%= b.listing ? b.listing.name : 'Deleted Listing' %>" data-mr="<%= b.listing ? b.listing.name : 'हटालेली सूची' %>" data-hi="<%= b.listing ? b.listing.name : 'हटाई गई सूची' %>"><%= b.listing ? b.listing.name : 'Deleted Listing' %></p>
                        <p class="text-xs text-gray-500"><%= b.listing ? b.listing.region : 'N/A' %></p>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-600">
                    <%= new Date(b.from).toLocaleDateString() %> - <%= new Date(b.to).toLocaleDateString() %>
                  </td>
                  <td class="px-6 py-4 font-medium text-gray-900">₹<%= b.amount %></td>
                  <td class="px-6 py-4">
                    <span class="px-3 py-1 rounded-full text-xs font-medium <%= b.status === 'confirmed' ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>" data-en="<%= b.status %>" data-mr="<%= b.status === 'confirmed' ? 'पुष्टीकृत' : (b.status === 'pending' ? 'अपूर्ण' : 'भरले') %>" data-hi="<%= b.status === 'confirmed' ? 'पुष्टि किया गया' : (b.status === 'pending' ? 'लंबित' : 'भुगतान किया गया') %>">
                      <%= b.status %>
                    </span>
                  </td>
                  <td class="px-6 py-4">
                    <% if (b.status === 'pending') { %>
                      <a href="/farmer/payment/<%= b._id %>" class="text-emerald-600 hover:text-emerald-700 font-medium text-sm hover:underline" data-en="Pay Now" data-mr="आता भरा" data-hi="अभी भरें">Pay Now</a>
                    <% } else if (b.status === 'confirmed') { %>
                      <span class="text-gray-400 text-sm" data-en="Confirmed" data-mr="पुष्टी केली" data-hi="पुष्टि किया गया">Confirmed</span>
                    <% } else { %>
                      <span class="text-gray-400 text-sm" data-en="Paid" data-mr="भरले" data-hi="भुगतान किया गया">Paid</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="p-8 text-center text-gray-500">
          No bookings yet. Start by renting some equipment!
        </div>
      <% } %>
    </div>

  </div>

  <!-- Booking Modal -->
  <div id="bookingModal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="closeBookingModal()"></div>
    <div class="relative bg-white rounded-3xl shadow-2xl p-8 animate-fade-in-up w-full max-w-md glass">
      <div class="flex justify-between items-center mb-6">
        <h3 class="text-2xl font-bold text-gray-900">Book Equipment</h3>
        <button onclick="closeBookingModal()" class="p-2 hover:bg-gray-100 rounded-full transition text-gray-500 hover:text-gray-700">
          <i data-lucide="x" class="w-6 h-6"></i>
        </button>
      </div>
      
      <div class="bg-emerald-50 p-5 rounded-2xl mb-6 flex items-center gap-4">
        <div class="w-16 h-16 bg-white rounded-2xl flex items-center justify-center text-emerald-600 shadow-sm">
          <i data-lucide="tractor" class="w-8 h-8"></i>
        </div>
        <div>
          <p class="text-sm text-emerald-800 font-medium" data-en="Selected Equipment" data-mr="निवडलेले उपकरण" data-hi="चयनित उपकरण">Selected Equipment</p>
          <p class="font-bold text-emerald-900 text-xl" id="modalEquipmentName">Tractor</p>
        </div>
      </div>

      <form id="bookingForm" method="POST" action="">
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 mb-3" data-en="Number of Days" data-mr="दिवसांची संख्या" data-hi="दिनों की संख्या">Number of Days</label>
          <div class="relative flex items-center justify-center">
            <button type="button" onclick="adjustDays(-1)" class="p-3 hover:bg-gray-100 rounded-xl text-gray-500 hover:text-gray-700 transition shadow-sm">
              <i data-lucide="minus" class="w-5 h-5"></i>
            </button>
            <input type="number" name="days" id="daysInput" value="1" min="1" 
                   class="w-20 text-center py-4 mx-2 border border-gray-200 rounded-xl font-bold text-xl focus:outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100" readonly>
            <button type="button" onclick="adjustDays(1)" class="p-3 hover:bg-gray-100 rounded-xl text-gray-500 hover:text-gray-700 transition shadow-sm">
              <i data-lucide="plus" class="w-5 h-5"></i>
            </button>
          </div>
        </div>

        <div class="flex justify-between items-center mb-8 py-4 bg-gray-50 rounded-2xl px-6">
          <span class="text-gray-700 font-medium" data-en="Total Amount" data-mr="एकूण रक्कम" data-hi="कुल राशि">Total Amount</span>
          <span class="font-bold text-emerald-600 text-3xl">₹<span id="totalAmount">0</span></span>
        </div>

        <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-4 rounded-2xl transition shadow-lg shadow-emerald-200 hover-lift btn-glow">
          <span class="flex items-center justify-center gap-2" data-en="Confirm & Pay" data-mr="पुष्टी करा आणि भरा" data-hi="पुष्टि करें और भुगतान करें">
            <i data-lucide="check-circle" class="w-5 h-5"></i>
            Confirm & Pay
          </span>
        </button>
      </form>
    </div>
  </div>


  <script src="/js/translation.js"></script>
    <script>
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }
    
    // Update translation button text based on current language
    function updateTranslationButtonText() {
      const btn = document.getElementById('translateBtnText');
      if (btn) {
        if (window.hindiTranslator && window.hindiTranslator.isHindi) {
          btn.textContent = 'English';
        } else {
          btn.textContent = 'हिंदी';
        }
      }
    }
    
    // Listen for language changes
    const originalTranslateToHindi = window.translateToHindi;
    const originalTranslateToEnglish = window.translateToEnglish;
    
    window.translateToHindi = function() {
      originalTranslateToHindi();
      setTimeout(updateTranslationButtonText, 100);
    };
    
    window.translateToEnglish = function() {
      originalTranslateToEnglish();
      setTimeout(updateTranslationButtonText, 100);
    };
    
    // Initialize button text when DOM is loaded
    document.addEventListener('DOMContentLoaded', function() {
      updateTranslationButtonText();
    });
    
    let currentPrice = 0;

    function escapeHtml(text) {
      var map = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;'
      };
      
      return text.replace(/[&<>"']/g, function(m) { return map[m]; });
    }

    function openBookingModal(id, name, price) {
      document.getElementById('bookingModal').classList.remove('hidden');
      document.getElementById('modalEquipmentName').innerText = name;
      document.getElementById('bookingForm').action = `/farmer/initiate-booking/${id}`;
      currentPrice = price;
      updateTotal();
      
      // Prevent background scrolling when modal is open
      document.body.style.overflow = 'hidden';
    }

    function closeBookingModal() {
      document.getElementById('bookingModal').classList.add('hidden');
      
      // Re-enable background scrolling
      document.body.style.overflow = 'auto';
    }

    function adjustDays(change) {
      const input = document.getElementById('daysInput');
      let val = parseInt(input.value) + change;
      if (val < 1) val = 1;
      input.value = val;
      updateTotal();
    }

    function updateTotal() {
      const days = parseInt(document.getElementById('daysInput').value);
      document.getElementById('totalAmount').innerText = days * currentPrice;
    }
    
    // Add event listeners after page loads
    document.addEventListener('DOMContentLoaded', function() {
      // Add click event listeners to all book now buttons
      const bookButtons = document.querySelectorAll('.book-now-button');
      bookButtons.forEach(button => {
        button.addEventListener('click', function() {
          const id = this.getAttribute('data-id');
          const name = this.getAttribute('data-name');
          const price = parseFloat(this.getAttribute('data-price'));
          openBookingModal(id, name, price);
        });
      });
      
      // Close modal with Escape key
      document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape' && !document.getElementById('bookingModal').classList.contains('hidden')) {
          closeBookingModal();
        }
      });
    });
  </script>
</body>
</html>