<!DOCTYPE html>
<html lang="en" id="html">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Farmer Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/modern.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
</head>
<body class="bg-gray-50">

  <!-- Navbar -->
  <nav class="sticky top-0 z-40 bg-white/80 backdrop-blur-md border-b border-gray-200">
    <div class="container mx-auto px-4 py-3 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <div class="bg-emerald-100 p-2 rounded-xl">
          <i data-lucide="tractor" class="w-6 h-6 text-emerald-600"></i>
        </div>
        <span class="text-xl font-bold text-gray-800" data-en="Farmer Portal" data-mr="शेतकरी पोर्टल">Farmer Portal</span>
      </div>
      
      <div class="flex items-center gap-4">
        <div class="hidden md:flex items-center gap-2 bg-emerald-50 px-4 py-2 rounded-full">
          <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
          <span class="text-sm font-medium text-emerald-700" data-en="Live Market" data-mr="थेट बाजार">Live Market</span>
        </div>
        <a href="/auth/logout" class="p-2 hover:bg-gray-100 rounded-full transition text-gray-500 hover:text-red-500">
          <i data-lucide="log-out" class="w-5 h-5"></i>
        </a>
      </div>
    </div>
  </nav>

  <div class="container mx-auto px-4 py-8">
    
    <!-- Search & Filter Section -->
    <div class="glass rounded-3xl p-6 mb-10 animate-fade-in-up">
      <form action="/farmer" method="GET" class="grid md:grid-cols-4 gap-4">
        <div class="md:col-span-2 relative">
          <i data-lucide="search" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400"></i>
          <input type="text" name="q" value="<%= query %>" placeholder="Search for tractors, seeders..." class="w-full pl-12 pr-4 py-3 rounded-xl border border-gray-200 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 outline-none transition bg-white/50">
        </div>
        
        <div class="relative">
          <i data-lucide="map-pin" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400"></i>
          <select name="region" class="w-full pl-12 pr-4 py-3 rounded-xl border border-gray-200 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 outline-none transition bg-white/50 appearance-none">
            <option value="">All Regions</option>
            <% REGIONS.forEach(r => { %>
              <option value="<%= r %>" <%= region == r ? 'selected' : '' %>><%= r %></option>
            <% }) %>
          </select>
        </div>

        <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 rounded-xl transition shadow-lg shadow-emerald-200 flex items-center justify-center gap-2">
          <i data-lucide="filter" class="w-5 h-5"></i> <span data-en="Filter" data-mr="फिल्टर">Filter</span>
        </button>
      </form>

      <!-- Category Tags -->
      <div class="flex flex-wrap gap-2 mt-4">
        <a href="/farmer" class="px-4 py-1.5 rounded-full text-sm font-medium transition <%= category === 'all' ? 'bg-emerald-600 text-white shadow-md' : 'bg-white text-gray-600 hover:bg-gray-100 border border-gray-200' %>">All</a>
        <% CATEGORIES.forEach(c => { %>
          <a href="/farmer?category=<%= c %>&region=<%= region %>&q=<%= query %>" class="px-4 py-1.5 rounded-full text-sm font-medium transition <%= category === c ? 'bg-emerald-600 text-white shadow-md' : 'bg-white text-gray-600 hover:bg-gray-100 border border-gray-200' %>">
            <%= c %>
          </a>
        <% }) %>
      </div>

      <!-- Listings Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
        <% if (listings.length > 0) { %>
          <% listings.forEach(l => { %>
            <div class="glass rounded-3xl p-6 hover:shadow-xl transition group flex flex-col h-full">
              
              <!-- Image Section -->
              <div class="relative h-48 mb-4 rounded-2xl overflow-hidden group-hover:scale-[1.02] transition-transform duration-300">
                <img src="<%= l.img %>" alt="<%= l.name %>" class="w-full h-full object-cover">
                <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold text-emerald-700 shadow-sm">
                  <%= l.category %>
                </div>
              </div>

              <div class="flex justify-between items-start mb-4">
                <div>
                  <h3 class="text-xl font-bold text-gray-900 mb-1"><%= l.name %></h3>
                  <p class="text-sm text-gray-500"><i data-lucide="map-pin" class="w-3 h-3 inline mr-1"></i><%= l.region %></p>
                </div>
              </div>
              
              <div class="flex items-center gap-2 mb-4 text-sm text-gray-500">
                <i data-lucide="user" class="w-4 h-4"></i>
                <span><%= l.sellerName || 'Verified Seller' %></span>
              </div>

              <div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-between">
                <div>
                  <span class="text-xs text-gray-400 block">Price per day</span>
                  <span class="text-xl font-bold text-gray-900">₹<%= l.pricePerDay %></span>
                </div>
                <button onclick="openBookingModal('<%= l._id %>', '<%= l.name %>', <%= l.pricePerDay %>)" class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-xl font-medium transition shadow-md shadow-emerald-100" data-en="Book Now" data-mr="आता बुक करा">
                  Book Now
                </button>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-span-full py-12 text-center">
            <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4 text-gray-400">
              <i data-lucide="search-x" class="w-10 h-10"></i>
            </div>
            <h3 class="text-xl font-semibold text-gray-600 mb-2" data-en="No equipment found" data-mr="कोणतीही उपकरणे सापडली नाहीत">No equipment found</h3>
            <p class="text-gray-500" data-en="Try adjusting your search filters" data-mr="आपले शोध फिल्टर समायोजित करण्याचा प्रयत्न करा">Try adjusting your search filters</p>
          </div>
        <% } %>
      </div>
    </div>

    <!-- My Bookings Section -->
    <h2 class="text-2xl font-bold text-gray-800 mb-6" data-en="My Bookings" data-mr="माझे बुकिंग">My Bookings</h2>
    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden mb-12">
      <% if (bookings.length > 0) { %>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50 border-b border-gray-100">
              <tr>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Equipment</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Dates</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Amount</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% bookings.forEach(b => { %>
                <tr class="hover:bg-gray-50/50 transition">
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 rounded-lg bg-gray-100 flex items-center justify-center text-gray-500">
                        <i data-lucide="tractor" class="w-5 h-5"></i>
                      </div>
                      <div>
                        <p class="font-medium text-gray-900"><%= b.listing.name %></p>
                        <p class="text-xs text-gray-500"><%= b.listing.region %></p>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-600">
                    <%= new Date(b.from).toLocaleDateString() %> - <%= new Date(b.to).toLocaleDateString() %>
                  </td>
                  <td class="px-6 py-4 font-medium text-gray-900">₹<%= b.amount %></td>
                  <td class="px-6 py-4">
                    <span class="px-3 py-1 rounded-full text-xs font-medium <%= b.status === 'confirmed' ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>">
                      <%= b.status %>
                    </span>
                  </td>
                  <td class="px-6 py-4">
                    <% if (b.status === 'pending') { %>
                      <a href="/farmer/payment/<%= b._id %>" class="text-emerald-600 hover:text-emerald-700 font-medium text-sm hover:underline">Pay Now</a>
                    <% } else { %>
                      <span class="text-gray-400 text-sm">Paid</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="p-8 text-center text-gray-500">
          No bookings yet. Start by renting some equipment!
        </div>
      <% } %>
    </div>

  </div>

  <!-- Booking Modal -->
  <div id="bookingModal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeBookingModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md bg-white rounded-3xl shadow-2xl p-8 animate-fade-in-up">
      <div class="flex justify-between items-center mb-6">
        <h3 class="text-2xl font-bold text-gray-900">Book Equipment</h3>
        <button onclick="closeBookingModal()" class="p-2 hover:bg-gray-100 rounded-full transition"><i data-lucide="x" class="w-5 h-5"></i></button>
      </div>
      
      <div class="bg-emerald-50 p-4 rounded-xl mb-6 flex items-center gap-4">
        <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-emerald-600 shadow-sm">
          <i data-lucide="tractor" class="w-6 h-6"></i>
        </div>
        <div>
          <p class="text-sm text-emerald-800 font-medium">Selected Equipment</p>
          <p class="font-bold text-emerald-900 text-lg" id="modalEquipmentName">Tractor</p>
        </div>
      </div>

      <form id="bookingForm" method="POST" action="">
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 mb-2">Number of Days</label>
          <div class="relative">
            <button type="button" onclick="adjustDays(-1)" class="absolute left-2 top-1/2 -translate-y-1/2 p-2 hover:bg-gray-100 rounded-lg text-gray-500"><i data-lucide="minus" class="w-4 h-4"></i></button>
            <input type="number" name="days" id="daysInput" value="1" min="1" class="w-full text-center py-3 border border-gray-200 rounded-xl font-bold text-lg focus:outline-none focus:border-emerald-500" readonly>
            <button type="button" onclick="adjustDays(1)" class="absolute right-2 top-1/2 -translate-y-1/2 p-2 hover:bg-gray-100 rounded-lg text-gray-500"><i data-lucide="plus" class="w-4 h-4"></i></button>
          </div>
        </div>

        <div class="flex justify-between items-center mb-8 text-lg">
          <span class="text-gray-600">Total Amount</span>
          <span class="font-bold text-emerald-600 text-2xl">₹<span id="totalAmount">0</span></span>
        </div>

        <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-4 rounded-xl transition shadow-lg shadow-emerald-200">
          Confirm & Pay
        </button>
      </form>
    </div>
  </div>


  <script>
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }
    
    let currentPrice = 0;

    function openBookingModal(id, name, price) {
      document.getElementById('bookingModal').classList.remove('hidden');
      document.getElementById('modalEquipmentName').innerText = name;
      document.getElementById('bookingForm').action = `/farmer/initiate-booking/${id}`;
      currentPrice = price;
      updateTotal();
    }

    function closeBookingModal() {
      document.getElementById('bookingModal').classList.add('hidden');
    }

    function adjustDays(change) {
      const input = document.getElementById('daysInput');
      let val = parseInt(input.value) + change;
      if (val < 1) val = 1;
      input.value = val;
      updateTotal();
    }

    function updateTotal() {
      const days = parseInt(document.getElementById('daysInput').value);
      document.getElementById('totalAmount').innerText = days * currentPrice;
    }
  </script>
</body>
</html>