<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Secure Payment - GreenEquip</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/modern.css" />
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  </head>
  <body class="bg-gray-50 min-h-screen flex items-center justify-center p-4">
    <div
      class="fixed inset-0 bg-gradient-to-br from-emerald-50 to-green-50 -z-10"
    ></div>
    <div class="max-w-4xl w-full mx-auto">
      <!-- Order Summary Card -->
      <div class="glass p-8 rounded-3xl h-fit mb-8">
        <h2
          class="text-2xl font-bold text-gray-800 mb-6 text-center flex items-center justify-center gap-2"
        >
          <i data-lucide="shopping-bag" class="w-6 h-6 text-emerald-600"></i>
          Booking Confirmation
        </h2>

        <div class="flex flex-col items-center mb-6">
          <div
            class="w-24 h-24 bg-emerald-100 rounded-2xl flex items-center justify-center text-emerald-600 mb-4"
          >
            <i data-lucide="tractor" class="w-12 h-12"></i>
          </div>
          <h3 class="font-bold text-xl text-gray-900 text-center">
            <%= listing.name %>
          </h3>
          <p class="text-gray-500 mt-1">
            Rental Duration:
            <span class="font-semibold text-gray-700"><%= days %> Days</span>
          </p>
        </div>

        <div class="bg-gray-50 rounded-2xl p-6 mb-6">
          <div
            class="flex justify-between items-center py-3 border-b border-gray-100"
          >
            <span class="text-gray-600">Subtotal</span>
            <span class="font-medium">₹<%= amount %></span>
          </div>
          <div
            class="flex justify-between items-center py-3 border-b border-gray-100"
          >
            <span class="text-gray-600">Platform Fee</span>
            <span class="font-medium">₹0</span>
          </div>
          <div class="flex justify-between items-center py-4">
            <span class="text-lg font-bold text-gray-900">Total Amount</span>
            <span class="text-2xl font-bold text-emerald-600"
              >₹<%= amount %></span
            >
          </div>
        </div>

        <div
          class="text-center bg-emerald-50 text-emerald-700 p-4 rounded-xl text-sm flex items-center justify-center gap-2"
        >
          <i data-lucide="shield-check" class="w-5 h-5"></i>
          <span>Secure transaction powered by Blockchain Technology</span>
        </div>
      </div>

      <!-- Payment Methods Card -->
      <div class="glass p-8 rounded-3xl h-fit">
        <h2 class="text-2xl font-bold text-gray-800 mb-6 text-center">
          Select Payment Method
        </h2>

        <div class="space-y-4">
          <!-- Card Payment -->
          <button
            onclick="payWithMethod('debit', '<%= bookingId %>', <%= amount %>, <%= days %>, <%= listing.onChainId %>)"
            class="w-full group glass hover:border-emerald-500 hover:bg-emerald-50 p-5 rounded-2xl flex items-center justify-between transition text-left hover-lift"
          >
            <div class="flex items-center gap-4">
              <div
                class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center text-blue-600"
              >
                <i data-lucide="credit-card" class="w-6 h-6"></i>
              </div>
              <div>
                <p
                  class="font-bold text-gray-800 group-hover:text-emerald-700 text-lg"
                >
                  Debit / Credit Card
                </p>
                <p class="text-sm text-gray-500">Instant secure payment</p>
              </div>
            </div>
            <i
              data-lucide="chevron-right"
              class="w-6 h-6 text-gray-300 group-hover:text-emerald-500"
            ></i>
          </button>

          <!-- UPI Payment -->
          <div class="rounded-2xl overflow-hidden border border-gray-200">
            <button
              onclick="toggleUpiForm()"
              class="w-full group hover:bg-emerald-50 p-5 flex items-center justify-between transition text-left hover-lift"
            >
              <div class="flex items-center gap-4">
                <div
                  class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center text-green-600"
                >
                  <i data-lucide="smartphone" class="w-6 h-6"></i>
                </div>
                <div>
                  <p
                    class="font-bold text-gray-800 group-hover:text-emerald-700 text-lg"
                  >
                    UPI Payment
                  </p>
                  <p class="text-sm text-gray-500">
                    Google Pay, PhonePe, Paytm
                  </p>
                </div>
              </div>
              <i
                data-lucide="chevron-down"
                class="w-6 h-6 text-gray-300 group-hover:text-emerald-500"
              ></i>
            </button>

            <div
              id="upi-form"
              class="hidden p-5 bg-gray-50 border-t border-gray-100"
            >
              <label class="block text-sm font-medium text-gray-700 mb-3"
                >Enter UPI ID</label
              >
              <div class="flex gap-3">
                <input
                  type="text"
                  id="upi-id"
                  placeholder="username@upi"
                  class="flex-1 px-4 py-3 rounded-xl border border-gray-200 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100 outline-none transition"
                />
                <button
                  id="submit-upi"
                  class="bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-3 rounded-xl font-medium transition btn-glow"
                >
                  Pay Now
                </button>
              </div>
            </div>
          </div>

          <!-- Crypto Payment -->
          <button
            onclick="payWithMethod('crypto', '<%= bookingId %>', <%= amount %>, <%= days %>, <%= listing.onChainId %>)"
            class="w-full group glass hover:border-purple-500 hover:bg-purple-50 p-5 rounded-2xl flex items-center justify-between transition text-left hover-lift"
          >
            <div class="flex items-center gap-4">
              <div
                class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center text-purple-600"
              >
                <i data-lucide="bitcoin" class="w-6 h-6"></i>
              </div>
              <div>
                <p
                  class="font-bold text-gray-800 group-hover:text-purple-700 text-lg"
                >
                  Pay with Crypto
                </p>
                <p class="text-sm text-gray-500">MetaMask (ETH)</p>
              </div>
            </div>
            <i
              data-lucide="chevron-right"
              class="w-6 h-6 text-gray-300 group-hover:text-purple-500"
            ></i>
          </button>
        </div>

        <p
          id="status"
          class="mt-8 text-center text-base font-medium text-gray-600 py-3 rounded-xl bg-gray-50"
        ></p>
      </div>
    </div>

    <script src="https://unpkg.com/ethers@5.7.2/dist/ethers.umd.min.js"></script>
    <script src="/js/payment.js"></script>
    <script>
      if (typeof lucide !== 'undefined') {
        lucide.createIcons();
      }

      function toggleUpiForm() {
        const form = document.getElementById('upi-form');
        form.classList.toggle('hidden');

        // Scroll to the form when it's opened
        if (!form.classList.contains('hidden')) {
          form.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      }

      // Hook into the existing showUpiForm function from payment.js if needed
      document.getElementById('submit-upi').addEventListener('click', () => {
        const upiId = document.getElementById('upi-id').value;
        if(!upiId) {
          alert("Please enter UPI ID");
          return;
        }

        // Validate UPI format (basic validation)
        const upiRegex = /^[a-zA-Z0-9._-]+@[a-zA-Z0-9.-]+$/;
        if (!upiRegex.test(upiId)) {
          alert("Please enter a valid UPI ID (e.g., username@upi)");
          return;
        }

        // Show processing status
        const statusElement = document.getElementById('status');
        statusElement.innerText = 'Processing your payment...';
        statusElement.className = 'mt-8 text-center text-base font-medium text-emerald-600 py-3 rounded-xl bg-emerald-50';

        // Call the existing logic
        payWithMethod('upi', '<%= bookingId %>', <%= amount %>, <%= days %>, <%= listing.onChainId %>);
      });
    </script>
  </body>
</html>
