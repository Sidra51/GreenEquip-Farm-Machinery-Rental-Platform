<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Secure Payment - GreenEquip</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/modern.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center p-4">

  <div class="max-w-4xl w-full grid md:grid-cols-2 gap-8">
    
    <!-- Order Summary -->
    <div class="glass p-8 rounded-3xl h-fit">
      <h2 class="text-xl font-bold text-gray-800 mb-6 flex items-center gap-2">
        <i data-lucide="shopping-bag" class="w-5 h-5 text-emerald-600"></i> Order Summary
      </h2>
      
      <div class="flex items-center gap-4 mb-6">
        <div class="w-20 h-20 bg-gray-100 rounded-xl flex items-center justify-center text-gray-400">
          <i data-lucide="tractor" class="w-10 h-10"></i>
        </div>
        <div>
          <h3 class="font-bold text-lg text-gray-900"><%= listing.name %></h3>
          <p class="text-sm text-gray-500">Rental Duration: <span class="font-semibold text-gray-700"><%= days %> Days</span></p>
        </div>
      </div>

      <div class="border-t border-gray-100 pt-4 space-y-2">
        <div class="flex justify-between text-gray-600">
          <span>Subtotal</span>
          <span>₹<%= amount %></span>
        </div>
        <div class="flex justify-between text-gray-600">
          <span>Platform Fee</span>
          <span>₹0</span>
        </div>
        <div class="flex justify-between text-xl font-bold text-emerald-600 pt-2 border-t border-gray-100 mt-2">
          <span>Total</span>
          <span>₹<%= amount %></span>
        </div>
      </div>

      <div class="mt-6 bg-emerald-50 text-emerald-700 p-3 rounded-xl text-sm flex items-center gap-2">
        <i data-lucide="shield-check" class="w-4 h-4"></i>
        Secure transaction powered by Blockchain
      </div>
    </div>

    <!-- Payment Methods -->
    <div class="bg-white p-8 rounded-3xl shadow-xl">
      <h2 class="text-xl font-bold text-gray-800 mb-6">Select Payment Method</h2>

      <div class="space-y-4">
        <!-- Card Payment -->
        <button onclick="payWithMethod('debit', '<%= bookingId %>', <%= amount %>, <%= days %>, <%= listing.onChainId %>)" class="w-full group border border-gray-200 hover:border-emerald-500 hover:bg-emerald-50 p-4 rounded-xl flex items-center justify-between transition text-left">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center text-blue-600">
              <i data-lucide="credit-card" class="w-5 h-5"></i>
            </div>
            <div>
              <p class="font-bold text-gray-800 group-hover:text-emerald-700">Debit / Credit Card</p>
              <p class="text-xs text-gray-500">Instant payment</p>
            </div>
          </div>
          <i data-lucide="chevron-right" class="w-5 h-5 text-gray-300 group-hover:text-emerald-500"></i>
        </button>

        <!-- UPI Payment -->
        <div class="border border-gray-200 rounded-xl overflow-hidden">
          <button onclick="toggleUpiForm()" class="w-full group hover:bg-emerald-50 p-4 flex items-center justify-between transition text-left">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center text-green-600">
                <i data-lucide="smartphone" class="w-5 h-5"></i>
              </div>
              <div>
                <p class="font-bold text-gray-800 group-hover:text-emerald-700">UPI</p>
                <p class="text-xs text-gray-500">Google Pay, PhonePe, Paytm</p>
              </div>
            </div>
            <i data-lucide="chevron-down" class="w-5 h-5 text-gray-300 group-hover:text-emerald-500"></i>
          </button>
          
          <div id="upi-form" class="hidden p-4 bg-gray-50 border-t border-gray-100">
            <label class="block text-sm font-medium text-gray-700 mb-2">Enter UPI ID</label>
            <div class="flex gap-2">
              <input type="text" id="upi-id" placeholder="username@upi" class="flex-1 px-4 py-2 rounded-lg border border-gray-200 focus:border-emerald-500 outline-none">
              <button id="submit-upi" class="bg-emerald-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-emerald-700 transition">Pay</button>
            </div>
          </div>
        </div>

        <!-- Crypto Payment -->
        <button onclick="payWithMethod('crypto', '<%= bookingId %>', <%= amount %>, <%= days %>, <%= listing.onChainId %>)" class="w-full group border border-gray-200 hover:border-purple-500 hover:bg-purple-50 p-4 rounded-xl flex items-center justify-between transition text-left">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center text-purple-600">
              <i data-lucide="bitcoin" class="w-5 h-5"></i>
            </div>
            <div>
              <p class="font-bold text-gray-800 group-hover:text-purple-700">Pay with Crypto</p>
              <p class="text-xs text-gray-500">MetaMask (ETH)</p>
            </div>
          </div>
          <i data-lucide="chevron-right" class="w-5 h-5 text-gray-300 group-hover:text-purple-500"></i>
        </button>
      </div>

      <p id="status" class="mt-6 text-center text-sm font-medium text-gray-600"></p>
    </div>
  </div>

  <script src="https://unpkg.com/ethers@5.7.2/dist/ethers.umd.min.js"></script>
  <script src="/js/payment.js"></script>
  <script>
    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }

    function toggleUpiForm() {
      const form = document.getElementById('upi-form');
      form.classList.toggle('hidden');
    }

    // Hook into the existing showUpiForm function from payment.js if needed, 
    // but here we are redefining the UI interaction.
    // We need to ensure the submit button calls the logic.
    document.getElementById('submit-upi').addEventListener('click', () => {
      const upiId = document.getElementById('upi-id').value;
      if(!upiId) return alert("Please enter UPI ID");
      // Call the existing logic (assuming payWithMethod handles 'upi' or we adapt)
      // Since payment.js expects showUpiForm to handle the UI, we might need to adapt.
      // Let's assume payWithMethod can handle it or we call the backend directly.
      // Actually, looking at payment.js (from memory), it likely has a specific flow.
      // Let's use the existing function signature:
      payWithMethod('upi', '<%= bookingId %>', <%= amount %>, <%= days %>, <%= listing.onChainId %>); 
      // Note: The original code had showUpiForm separate. I'll make sure payment.js logic is triggered.
    });
  </script>
</body>
</html>