<nav
  class="bg-green-600 text-white px-6 py-4 flex justify-between items-center"
>
  <div class="text-xl font-bold">
    <a href="/" class="speakable" data-mr="फार्मचेन" data-hi="फार्मचेन"
      >फार्मचेन</a
    >
  </div>

  <ul class="flex space-x-6 items-center">
    <!-- Translation Button -->
    <li>
      <button
        id="translateBtn"
        onclick="toggleLanguage()"
        class="flex items-center gap-2 text-white hover:text-yellow-300 transition font-medium"
        aria-label="Toggle Language"
      >
        <i data-lucide="globe" class="w-5 h-5"></i>
        <span id="translateBtnText">Translate</span>
      </button>
    </li>

    <% if (typeof user !== 'undefined' && user) { %>
    <li
      class="speakable"
      data-mr="आपले स्वागत आहे, <%= user.name %>"
      data-hi="आपका स्वागत है, <%= user.name %>"
    >
      आपले स्वागत आहे, <span class="font-semibold"><%= user.name %></span> (<%=
      user.role %>)
    </li>

    <% if (user.role === "farmer") { %>
    <li>
      <a
        href="/farmer"
        class="hover:underline speakable"
        data-mr="डॅशबोर्ड"
        data-hi="डैशबोर्ड"
        >डॅशबोर्ड</a
      >
    </li>
    <% } else if (user.role === "seller") { %>
    <li>
      <a
        href="/seller"
        class="hover:underline speakable"
        data-mr="डॅशबोर्ड"
        data-hi="डैशबोर्ड"
        >डॅशबोर्ड</a
      >
    </li>
    <% } else if (user.role === "admin") { %>
    <li>
      <a
        href="/admin"
        class="hover:underline speakable"
        data-mr="प्रशासक"
        data-hi="व्यवस्थापक"
        >प्रशासक</a
      >
    </li>
    <% } %>

    <li>
      <a
        href="/auth/logout"
        class="bg-red-500 px-4 py-2 rounded-lg hover:bg-red-600 transition-colors speakable"
        data-mr="लॉगआउट"
        data-hi="लॉग आउट"
        >लॉगआउट</a
      >
    </li>
    <% } %>
  </ul>
</nav>

<!-- Translation Script -->
<script src="/js/translation.js"></script>

<script>
  // Update translation button text based on current language
  function updateTranslationButtonText() {
    const btn = document.getElementById("translateBtnText");
    if (btn) {
      if (window.hindiTranslator && window.hindiTranslator.isHindi) {
        btn.textContent = "English";
      } else {
        btn.textContent = "हिंदी";
      }
    }
  }

  // Listen for language changes
  const originalTranslateToHindi = window.translateToHindi;
  const originalTranslateToEnglish = window.translateToEnglish;

  window.translateToHindi = function () {
    originalTranslateToHindi();
    setTimeout(updateTranslationButtonText, 100);
  };

  window.translateToEnglish = function () {
    originalTranslateToEnglish();
    setTimeout(updateTranslationButtonText, 100);
  };

  // Initialize button text when DOM is loaded
  document.addEventListener("DOMContentLoaded", function () {
    updateTranslationButtonText();
  });
</script>
